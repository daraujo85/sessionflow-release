# =============================================================================
# SessionFlow — template de variáveis de ambiente (sem segredos)
# Copie para .env e preencha. Stack 100% local (docker-compose.yml).
# =============================================================================

# --- MongoDB ---
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=
MONGO_DB=sessionflow
MONGO_APP_USERNAME=sessionflow
MONGO_APP_PASSWORD=
MONGO_URI=mongodb://sessionflow:PASS@mongo:27017/sessionflow?authSource=sessionflow
MONGO_URI_HOST=mongodb://sessionflow:PASS@127.0.0.1:27017/sessionflow?authSource=sessionflow

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=sessionflow
RABBITMQ_DEFAULT_PASS=
RABBITMQ_VHOST=/
RABBITMQ_URI=amqp://sessionflow:PASS@rabbitmq:5672/
RABBITMQ_URI_HOST=amqp://sessionflow:PASS@127.0.0.1:5672/

# --- Portas publicadas no host (somente 127.0.0.1) ---
MONGO_HOST_PORT=27017
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_HOST_PORT=15672
API_HOST_PORT=8000
FRONTEND_HOST_PORT=4200

# Autenticação (single-user)
SESSIONFLOW_PASSWORD=
SESSIONFLOW_JWT_SECRET=
SESSIONFLOW_EMAIL=
SESSIONFLOW_RP_ID=
SESSIONFLOW_RP_ORIGIN=
